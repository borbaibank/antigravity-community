# Antigravity Binance USDT-M Futures bot — environment template
# แม่แบบตัวแปรสภาพแวดล้อมสำหรับบอท Binance USDT-M Futures
# Copy to .env and fill in secrets:  cp .env.example .env
# คัดลอกเป็น .env แล้วกรอกค่าลับ:  cp .env.example .env
# Never commit .env (it is in .gitignore).
# ห้าม commit ไฟล์ .env (อยู่ใน .gitignore แล้ว)

# ── Mode & Binance API ───────────────────────────────────────────────────────
# โหมดการทำงาน & Binance API
# Paper by default. Set LIVE_MODE=true only when you intend real orders.
# ค่าเริ่มต้นเป็น Paper — ตั้ง LIVE_MODE=true เมื่อต้องการส่งออเดอร์จริง
LIVE_MODE=false

# Dashboard HTTP port
# พอร์ต HTTP ของแดชบอร์ด
# Use 8765 (Chrome/Edge block 6000 with ERR_UNSAFE_PORT)
DASHBOARD_PORT=8765

# Order routing: testnet | mainnet
# เส้นทางออเดอร์: testnet | mainnet
ORDER_ENV=mainnet
# Price/kline WebSocket + REST market data (can differ from ORDER_ENV)
# ราคา WebSocket + REST ข้อมูลตลาด (อาจต่างจาก ORDER_ENV ได้)
PRICE_FEED_ENV=mainnet

# Account type: futures_regular | leader_trade
# ประเภทบัญชี: futures_regular | leader_trade
BINANCE_API_ACCOUNT_TYPE=futures_regular

# Standard USDT-M futures keys (used when BINANCE_API_ACCOUNT_TYPE=futures_regular)
# API Key มาตรฐาน USDT-M (ใช้เมื่อ BINANCE_API_ACCOUNT_TYPE=futures_regular)
BINANCE_FUTURES_API_KEY=
BINANCE_FUTURES_API_SECRET=

# Leader trade keys (used when BINANCE_API_ACCOUNT_TYPE=leader_trade)
# API Key สำหรับ Leader Trade (ใช้เมื่อ BINANCE_API_ACCOUNT_TYPE=leader_trade)
BINANCE_LEADER_API_KEY=
BINANCE_LEADER_API_SECRET=

# Legacy aliases (optional; futures keys above take precedence when set)
# ชื่อเก่า (ไม่บังคับ; ถ้ากรอก futures keys ด้านบนจะใช้ค่านั้นก่อน)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Deprecated — use ORDER_ENV instead
# เลิกใช้แล้ว — ใช้ ORDER_ENV แทน
# BINANCE_TESTNET=false

# SL/TP placement mode (dashboard overrides via POST /api/sltp-mode):
# โหมดวาง SL/TP (แดชบอร์ดแก้ได้ผ่าน POST /api/sltp-mode):
#   local            — bot-managed SL+TP (no Binance algo orders)
#   local            — บอทจัดการ SL+TP เอง (ไม่ใช้ algo order บน Binance)
#   binance          — STOP+TP algo on exchange (~200 cap mainnet)
#   binance          — STOP+TP algo บน exchange (mainnet จำกัด ~200 ออเดอร์)
#   hybrid           — SL on exchange, TP bot-managed
#   hybrid           — SL บน exchange, TP บอทจัดการ
#   binance_fallback — exchange SL+TP when ≥2 algo slots free, else local both
#   binance_fallback — SL+TP บน exchange ถ้ามี algo slot ≥2 ว่าง ไม่งั้นใช้ local ทั้งคู่
# Legacy LOCAL_SLTP=true maps to local when SLTP_MODE is unset.
# LOCAL_SLTP=true แบบเก่าจะเทียบเท่า local ถ้าไม่ได้ตั้ง SLTP_MODE
SLTP_MODE=binance_fallback
LOCAL_SLTP=false

# Exchange SL/TP vs mark (live algo orders; LOCAL_SLTP skips mark nudge)
# SL/TP บน exchange เทียบกับ mark price (LOCAL_SLTP จะไม่ปรับ mark nudge)
MARK_FILL_SANITY_PCT=0.03
EXCHANGE_MARK_NUDGE_PCT=0.005
MAX_EXCHANGE_PROTECTION_NUDGE_PCT=0.02

# Position sizing (.env only — dashboard cannot change; restart required)
# ขนาดพอซิชัน (ตั้งใน .env เท่านั้น — แดชบอร์ดแก้ไม่ได้ ต้องรีสตาร์ท)
NOTIONAL_SIZE=100
MARGIN_SIZE=20
LEVERAGE=5

# ── Dashboard auth ─────────────────────────────────────────────────────────────
# การยืนยันตัวตนแดชบอร์ด
DASHBOARD_AUTH_ENABLED=false
DASHBOARD_PASSCODE=
# Comma-separated origins, e.g. http://localhost:6000,https://bot.example.com
# ระบุ origin คั่นด้วย comma เช่น http://localhost:6000,https://bot.example.com
# Leave empty to allow all origins (not recommended in production)
# ว่างไว้ = อนุญาตทุก origin (ไม่แนะนำใน production)
DASHBOARD_ALLOWED_ORIGINS=

# LIVE All-tab equity curve: account margin balance from this USD start (0 = strategy PnL curve)
# เส้น equity curve โหมด LIVE: ยอด margin เริ่มต้น USD (0 = ใช้กราฟ PnL ของกลยุทธ์)
EQUITY_CURVE_MARGIN_BASELINE=7000

# Paper tab starting balance (per tab; used for ledger + ROI basis)
# ยอดเริ่มต้นต่อ tab ในโหมด Paper (ใช้คำนวณ ledger + ROI)
INITIAL_BALANCE=7000

# Max concurrent kline REST requests during candle scans (lower = safer vs 429)
# จำนวน REST kline พร้อมกันสูงสุดตอนสแกนแท่งเทียน (ต่ำลง = ปลอดภัยกว่า rate limit 429)
KLINE_FETCH_CONCURRENCY=25

# ── Risk & circuit breaker ───────────────────────────────────────────────────
# ความเสี่ยง & Circuit Breaker
CIRCUIT_BREAKER_DAILY_LOSS=500
MIN_ENTRY_AVAILABLE_MARGIN=100
# Symbol filter / leaderboard rolling window (last N closed trades per tab+symbol)
# หน้าต่าง rolling ของ symbol filter / leaderboard (N เทรดปิดล่าสุดต่อ tab+symbol)
SYMBOL_FILTER_ROLLING_WINDOW=30
MAX_FUNDING_RATE_ABS=0.01
MAX_SPREAD_PCT=0.001
MAX_ENTRY_SIGNAL_DRIFT_PCT=0.003
# Block new entries when configured notional (margin × leverage) exceeds this USD cap (0 = off)
# บล็อกการเข้าเทรดใหม่เมื่อ notional (margin × leverage) เกินเพดาน USD นี้ (0 = ปิด)
MAX_NOTIONAL_SIZE=0

# ── Telegram (TP/SL exits and errors only) ───────────────────────────────────
# Telegram (แจ้งเตือนเฉพาะ TP/SL และ error)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Pionex (dashboard balance card; read-only) ─────────────────────────────
# Pionex (การ์ดยอดเงินในแดชบอร์ด; อ่านอย่างเดียว)
PIONEX_API_KEY=
PIONEX_API_SECRET=
# Poll interval for wallet/balancesFull (seconds)
# ช่วงเวลาดึงยอด wallet/balancesFull (วินาที)
PIONEX_BALANCE_POLL_SEC=60
# Optional manual USDT/THB rate override (0 = auto from Binance TH / Frankfurter)
# อัตรา USDT/THB กำหนดเอง (0 = ดึงอัตโนมัติจาก Binance TH / Frankfurter)
PIONEX_USDT_THB_RATE=0

# ── Paper trading cost model ───────────────────────────────────────────────────
# โมเดลต้นทุน Paper trading
PAPER_ENTRY_FEE_PCT=0.0005
PAPER_EXIT_MAKER_FEE_PCT=0.0002
PAPER_EXIT_TAKER_FEE_PCT=0.0005
PAPER_SLIPPAGE_PCT=0.0003

# ── Candle scan & live entry timing ────────────────────────────────────────────
# การสแกนแท่งเทียน & จังหวะเข้าเทรด Live
# Ticker prescreen at minute UTC (default :58) → kline scan uses watchlist at hour open
# กรอง ticker ก่อนปิดแท่ง (default นาที 58) → ต้นชั่วโมงสแกน kline เฉพาะ list
KLINE_PRESCREEN_ENABLED=1
KLINE_PRESCREEN_MINUTE=58
KLINE_PRESCREEN_TOP_N=500
KLINE_PRESCREEN_MIN_CHG_PCT=1.5
KLINE_PRESCREEN_RANGE_EDGE=0.40
# Fetch klines after candle close (effective delay = max of these two; min 10s for kline open to settle)
# ดึง kline หลังแท่งปิด (ดีเลย์จริง = ค่ามากสุดของสองตัวนี้; ขั้นต่ำ 10s ให้แท่งใหม่ settle)
KLINE_FETCH_DELAY_SEC=10
KLINE_FETCH_MIN_DELAY_SEC=10
# Live local SL/TP: grace period after entry before bot-managed exit checks
# SL/TP local โหมด Live: ช่วงรอหลังเข้าเทรดก่อนเช็ค exit ของบอท
ENTRY_LOCAL_SL_GRACE_SEC=30
# Seconds between each candidate entry in a batch
# วินาทีระหว่างการเข้าเทรดแต่ละตัวใน batch
ENTRY_STAGGER_SEC=2
# Wait for mark at-or-better than signal ep before entry (live + paper); skip if not ready in time
# รอ mark ดีกว่าหรือเท่ากับ ep สัญญาณก่อนเข้า (live + paper); ข้ามถ้าไม่ทันเวลา
ENTRY_WAIT_FOR_BETTER_PRICE=1
ENTRY_PRICE_WAIT_MAX_SEC=600
ENTRY_PRICE_POLL_SEC=2
# Min improvement vs signal ep before entry (0 = at-or-better; 0.001 = 0.1% better).
# ปรับราคาขั้นต่ำเทียบ ep สัญญาณก่อนเข้า (0 = ดีกว่าหรือเท่า; 0.001 = ดีกว่า 0.1%)
ENTRY_MIN_PRICE_IMPROVE_PCT=0.001
# Entry wait / -4192 retry price: last (contract) or mark (index).
# ราคาอ้างอิงตอนรอเข้า / retry -4192: last (สัญญา) หรือ mark (ดัชนี)
ENTRY_TRIGGER_PRICE=last
# Entry: market or limit GTC at signal ep
# การเข้าเทรด: market หรือ limit GTC ที่ ep สัญญาณ
ENTRY_ORDER_STYLE=limit
ENTRY_LIMIT_TIF=GTC
ENTRY_LIMIT_MAX_AGE_SEC=600
# Exchange TP: market or TAKE_PROFIT limit (SL stays STOP_MARKET)
# TP บน exchange: market หรือ TAKE_PROFIT limit (SL ยังเป็น STOP_MARKET)
SLTP_TP_STYLE=limit
ENTRY_LIMIT_TP_PRICE_MODE=same_as_trigger
CLOSE_ALL_STAGGER_SEC=2
CLOSE_ALL_PREFLIGHT=1
CLOSE_ALL_RETRY_SEC=60

# Binance -4192 (Cooling-off Period): cooling delay, then poll until mark is at-or-better than signal ep
# Binance -4192 (ช่วงพัก): รอคูลดาวน์ แล้ว poll จน mark ดีกว่าหรือเท่า ep สัญญาณ
ENTRY_4192_RETRY_DELAY_SEC=10
ENTRY_4192_PRICE_POLL_SEC=2
ENTRY_4192_MAX_RETRIES=5
# Max seconds after signal candle close before retry is dropped (600 = 10 min)
# วินาทีสูงสุดหลังแท่งสัญญาณปิดก่อนยกเลิก retry (600 = 10 นาที)
ENTRY_4192_RETRY_MAX_AGE_SEC=600

# Defer userTrades / PnL work while candle eval + entries run
# เลื่อนงาน userTrades / PnL ขณะประเมินแท่งเทียน + เข้าเทรด
ENTRY_EVAL_BUDGET_SEC=180
ENTRY_BUSY_BUFFER_SEC=90

# ── Live sync & REST rate limits ───────────────────────────────────────────────
# ซิงค์ Live & จำกัด REST rate limit
BINANCE_IP_BAN_DEFAULT_BACKOFF_SEC=120

# Bulk userTrades REST for dashboard (0=bot history + income; 1=round-robin Binance closes)
# ดึง userTrades REST จำนวนมากสำหรับแดชบอร์ด (0=ประวัติบอท+income; 1=round-robin ปิดจาก Binance)
BINANCE_CLOSE_HISTORY_ENABLED=0
BINANCE_CLOSE_HISTORY_DAYS=90
# Max closed trades kept in paper_state history (trim on new closes)
HISTORY_CAP=50000
# Max closes per dashboard WebSocket message (state HISTORY_CAP can be larger)
# จำกัดจำนวนไม้ปิดต่อข้อความ WebSocket แดชบอร์ด (HISTORY_CAP ใน state อาจมากกว่า)
DASHBOARD_WS_HISTORY_LIMIT=800
DASHBOARD_HISTORY_PAGE_MAX=200
# Max chart points from GET /api/equity-curve (downsampled when history is larger)
DASHBOARD_EQUITY_CURVE_MAX_POINTS=2000
BINANCE_CLOSE_HISTORY_SYMBOL_CAP=40
BINANCE_CLOSE_HISTORY_TTL_SEC=300
BINANCE_CLOSE_HISTORY_REFRESH_SYMBOL_CAP=15
BINANCE_CLOSE_HISTORY_BATCH_SIZE=5
BINANCE_CLOSE_HISTORY_SYMBOL_DELAY_SEC=0.25

EXCHANGE_ACCOUNT_POLL_SEC_UDS=90
EXCHANGE_ACCOUNT_POLL_SEC_NO_UDS=15
EXCHANGE_ACCOUNT_SYNC_SEC_UDS=120
EXCHANGE_ACCOUNT_SYNC_SEC_NO_UDS=60
EXCHANGE_ACCOUNT_SYNC_SEC_UDS_CONNECTED=300
UDS_ACCOUNT_FRESH_SEC=600

PNL_REPAIR_STARTUP_DELAY_SEC=120
PNL_REPAIR_BATCH_SIZE=3
PNL_REPAIR_BATCH_PAUSE_SEC=5.0
PNL_REPAIR_ENTRY_DELAY_SEC=1.0
PNL_REPAIR_DEFER_POLL_SEC=10.0
